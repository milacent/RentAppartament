# Backend Configuration
DEBUG=False
APP_NAME=ApartmentForRent
VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL Database
POSTGRES_USER=apartment_user
POSTGRES_PASSWORD=password
POSTGRES_DB=apartment_rent
DATABASE_URL=postgresql://apartment_user:password@postgres:5432/apartment_rent

# Security & JWT
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# ML Model
MODEL_PATH=/app/app/rental_price_model.pkl
PRICE_CALIBRATION_FACTOR=1
USE_COLAB_PREDICTION=True

# CORS (Frontend URL)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database Settings (SQLAlchemy)
SQLALCHEMY_ECHO=False

# Monitoring is not configured by default in this repository.
# Remove or add monitoring settings only if you add a compatible monitoring stack.
